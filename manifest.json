{
    "manifest_version": 3,
    "name": "FontMapper",
    "version": "0.1.0",
    "description": "Map any website's fonts to your local fonts — per domain. Your web, your typography.",
    "permissions": ["activeTab", "storage", "fontSettings", "scripting"],
    "host_permissions": ["<all_urls>"],
    "action": {
        "default_popup": "popup.html",
        "default_title": "FontMapper"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_start",
            "all_frames": false
        }
    ]
}
